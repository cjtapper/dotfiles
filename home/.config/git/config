[include]
  path = personal

[alias]
	st = status

[pull]
	rebase = true

[init]
	defaultBranch = main
	templatedir = ~/.config/git/template

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
